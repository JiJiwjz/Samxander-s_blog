---
import { Button, Collapse, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import ProjectSection from '@/components/projects/ProjectSection.astro'

const headings = [
  { depth: 2, slug: 'research', text: 'Research' },
  { depth: 2, slug: 'projects', text: 'Projects' }
]
---

<PageLayout title='Projects' {headings} view>
  <p>
    以下是我的部分科研项目和开源作品，持续更新中。
  </p>

  <h2 id='research'>Research</h2>
  <ProjectSection
    projects={[
      {
        name: '📄 待补充',
        description: '论文 / 科研项目介绍',
        links: [
          { type: 'github', href: 'https://github.com/JiJiwjz' }
        ]
      }
    ]}
  />

  <h2 id='projects'>Projects</h2>
  <ProjectSection
    projects={[
      {
        name: '📝 Samxander Blog',
        description: 'Personal blog built with Astro + Pure theme',
        links: [
          { type: 'github', href: 'https://github.com/JiJiwjz/Samxander-s_blog' },
          { type: 'site', href: 'https://samxander.cn' }
        ]
      }
    ]}
  />
</PageLayout>
